      "Read(//System/Library/Frameworks/PDFKit.framework/**)"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~/*)",
      "Bash(dd:*)"
    ],
    "ask": [
      "Bash(find *-exec*)",
      "Bash(find *-execdir*)",
      "Bash(find *-delete*)",
      "Bash(find *-ok*)",
      "Bash(rm:*)",
      "Bash(rmdir:*)",
      "Bash(shred:*)",
      "Bash(wipe:*)",
      "Bash(*force*)",
      "Bash(*recursive*)",
      "Bash(dd:*)",
      "Bash(mkfs:*)",
      "Bash(format:*)",
      "Bash(chmod 000*)",
      "Bash(chown root:*)",
      "Bash(git push*)",
      "Bash(git reset*)",
      "Bash(git clean*)",
      "Bash(git rebase*)",
      "Bash(git checkout -f)",
      "Bash(docker rm*)",
      "Bash(docker rmi*)",
      "Bash(docker volume rm*)",
      "Bash(kubectl delete*)",
      "Bash(kubectl apply --force*)",
      "Bash(kubectl delete -f*)",
      "Bash(cargo clean)",
      "Bash(npm cache clean)",
      "Bash(pip uninstall*)",
      "Bash(uv uninstall*)",
      "Bash(ssh:*)",
      "Bash(scp:*)",
      "Bash(rsync:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/dotfiles/script/playsound.sh ~/dotfiles/materials/audio/claude_hooks/pre_tool_use.m4a"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/dotfiles/script/playsound.sh ~/dotfiles/materials/audio/claude_hooks/post_tool_use.m4a"
          }
        ]
      }
    ],
