      "Bash(git branch:*)",
      "Bash(git tag:*)",
      "Bash(git remote -v)",
      "Bash(git config:*)",
      "Bash(git rev-parse:*)",
      "Bash(git describe:*)",
      "Bash(cargo build:*)",
      "Bash(cargo check:*)",
      "Bash(cargo test:*)",
      "Bash(cargo clippy:*)",
      "Bash(npm test:*)",
      "Bash(npm run test*)",
      "Bash(npx tsc:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(rga:*)",
      "Bash(jq:*)",
      "Bash(yq:*)",
      "Bash(docker ps)",
      "Bash(docker images)",
      "Bash(docker inspect:*)",
      "Bash(docker logs:*)",
      "Bash(docker-compose ps)",
      "Bash(kubectl get:*)",
      "Bash(kubectl describe:*)",
      "Bash(kubectl logs:*)",
      "Skill(agent-browser)",
      "Skill(agent-browser:*)",
      "Bash(agent-browser *)",
      "Bash(npx agent-browser *)",
      "mcp__context7__resolve-library-id",
