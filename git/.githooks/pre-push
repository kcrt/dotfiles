#!/bin/bash
# Pre-push checks for version tags:
#   1. Warn on unexpected tag format (v.1.2.3 instead of v1.2.3)
#   2. Check version consistency with project files
#      (package.json, Cargo.toml, pyproject.toml, pubspec.yaml, Xcode)
#   3. Warn when tag is not on the release branch

# Source shared version detection library
source "$HOME/dotfiles/script/lib/detect-project-version.sh"

while read local_ref local_sha remote_ref remote_sha; do
  if [[ "$remote_ref" == refs/tags/v* ]]; then
    tag_name="${remote_ref#refs/tags/}"

    # Warn on unexpected tag format like v.1.2.3 (expected: v1.2.3)
    if [[ "$tag_name" =~ ^v\. ]]; then
      echo "WARNING: Tag '$tag_name' does not follow the expected format. Did you mean '${tag_name/v./v}'?"
      read -p "Are you sure you want to push this tag? (y/N) " answer </dev/tty
      if [[ "$answer" != [yY] ]]; then
        echo "Aborted."
        exit 1
      fi
    fi

    # Check version consistency with project files
    tag_version="${tag_name#v}"
    if [[ "$tag_version" =~ ^[0-9]+\.[0-9]+\.[0-9]+ ]]; then
      mismatches=$(check_version_consistency "$tag_version" "$local_sha")
      if [[ -n "$mismatches" ]]; then
        echo "WARNING: Tag '$tag_name' version does not match project files:"
        echo "$mismatches"
        read -p "Are you sure you want to push this tag? (y/N) " answer </dev/tty
        if [[ "$answer" != [yY] ]]; then
          echo "Aborted."
          exit 1
        fi
      fi
    fi

    if git merge-base --is-ancestor "$local_sha" release 2>/dev/null ||
       git merge-base --is-ancestor "$local_sha" origin/release 2>/dev/null; then
      continue
    fi
    echo "WARNING: Tag '$tag_name' (commit ${local_sha:0:8}) is not on the release branch."
    read -p "Are you sure you want to push this tag? (y/N) " answer </dev/tty
    if [[ "$answer" != [yY] ]]; then
      echo "Aborted."
      exit 1
    fi
  fi
done
