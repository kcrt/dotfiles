#!/bin/bash
# Pre-commit checks:
#   1. Prevent committing files that may contain secrets or sensitive data
#   2. Warn on large files

FORBIDDEN_PATTERNS=(
  'PRIVATE KEY'
  'ssh-rsa AAAA'
  'ssh-ed25519 AAAA'
  'BEGIN RSA PRIVATE KEY'
  'BEGIN DSA PRIVATE KEY'
  'BEGIN EC PRIVATE KEY'
  'BEGIN OPENSSH PRIVATE KEY'
  'BEGIN PGP PRIVATE KEY'
  'AKIA[0-9A-Z]{16}'           # AWS Access Key ID
  'sk-[a-zA-Z0-9]{20,}'        # OpenAI / Anthropic API key
  'ghp_[a-zA-Z0-9]{36}'        # GitHub personal access token
  'gho_[a-zA-Z0-9]{36}'        # GitHub OAuth token
  'glpat-[a-zA-Z0-9\-]{20,}'   # GitLab personal access token
  'xox[bpors]-[a-zA-Z0-9\-]+'  # Slack token
)

FORBIDDEN_FILES=(
  '\.pem$'
  '\.p12$'
  '\.pfx$'
  '\.key$'
  '\.keystore$'
  '\.jks$'
  '\.env$'
  '\.env\.local$'
  '\.env\.production$'
  'id_rsa$'
  'id_ed25519$'
  'id_ecdsa$'
  'credentials\.json$'
  'service.account\.json$'
)

found=0

# Check staged files (only added/modified content, skip deleted files)
staged_files=$(git diff --cached --name-only --diff-filter=d)
if [[ -z "$staged_files" ]]; then
  exit 0
fi

# Check filenames
for pattern in "${FORBIDDEN_FILES[@]}"; do
  matches=$(echo "$staged_files" | grep -E "$pattern" || true)
  if [[ -n "$matches" ]]; then
    echo "WARNING: Potentially sensitive file(s) staged for commit:"
    echo "$matches" | sed 's/^/  /'
    found=1
  fi
done

# Check file contents for secret patterns
for pattern in "${FORBIDDEN_PATTERNS[@]}"; do
  matches=$(git diff --cached -G"$pattern" --name-only || true)
  if [[ -n "$matches" ]]; then
    echo "WARNING: Potential secret detected (pattern: ${pattern:0:30}...) in:"
    echo "$matches" | sed 's/^/  /'
    found=1
  fi
done

# Check for large files (> 5MB)
MAX_SIZE=$((5 * 1024 * 1024))
while IFS= read -r file; do
  file_size=$(git cat-file -s ":$file" 2>/dev/null || echo 0)
  if [[ "$file_size" -gt "$MAX_SIZE" ]]; then
    size_mb=$(echo "scale=1; $file_size / 1048576" | bc)
    echo "WARNING: Large file staged: $file (${size_mb}MB)"
    found=1
  fi
done <<< "$staged_files"

if [[ "$found" -eq 1 ]]; then
  read -p "Proceed with commit? (y/N) " answer </dev/tty
  if [[ "$answer" != [yY] ]]; then
    echo "Aborted."
    exit 1
  fi
fi
